# Scraping
HEADLESS=1
THROTTLE_MS=1200
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36

# OpenRouter configuration:
# - Set `OPENROUTER_API_KEY`
# - Optionally set `OPENROUTER_SITE_URL` + `OPENROUTER_APP_NAME`
# - Or set the generic `OPENAI_*` variables directly
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Model cost/time controls
MAX_LLM_REVIEWS=300

# Limits
MAX_PRODUCTS_PER_BRAND=12
MAX_REVIEWS_PER_ASIN=40
MAX_REVIEWS_PER_BRAND=120
